{
  "name": "document_visual",
  "document": {
    "name": "document_visual",
    "fields": [
      {
        "name": "document_id",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "document_title",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "document_type",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "page_number",
        "type": "int",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "page_count",
        "type": "int",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "document_path",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "creation_timestamp",
        "type": "long",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "colpali_embedding",
        "type": "tensor<bfloat16>(patch{}, v[128])",
        "indexing": [
          "attribute"
        ]
      },
      {
        "name": "colpali_embedding_binary",
        "type": "tensor<int8>(patch{}, v[16])",
        "indexing": [
          "attribute",
          "index"
        ]
      },
      {
        "name": "entity_ids",
        "type": "array<string>",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "relation_ids",
        "type": "array<string>",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "claim_ids",
        "type": "array<string>",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      }
    ]
  },
  "fieldsets": [
    {
      "name": "default",
      "fields": [
        "document_title"
      ]
    }
  ],
  "rank_profiles": [
    {
      "name": "default",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(colpali_embedding_binary)), v)), max, patch), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "bm25_only",
      "first_phase": "bm25(document_title)",
      "timeout": 2.0
    },
    {
      "name": "float_float",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(colpali_embedding), float), v), max, patch), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "binary_binary",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(colpali_embedding_binary)), v)), max, patch), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "float_binary",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * unpack_bits(attribute(colpali_embedding_binary)), v), max, patch), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "phased",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        },
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(colpali_embedding_binary)), v)), max, patch), querytoken)"
        },
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(colpali_embedding), float), v), max, patch), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "second_phase": {
        "expression": "max_sim",
        "rerank_count": 100
      },
      "timeout": 5.0
    },
    {
      "name": "hybrid_float_bm25",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "visual_sim_float",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(colpali_embedding), float), v), max, patch), querytoken)"
        },
        {
          "name": "text_sim",
          "expression": "bm25(document_title)"
        }
      ],
      "first_phase": "visual_sim_float",
      "second_phase": {
        "expression": "text_sim",
        "rerank_count": 100
      },
      "timeout": 2.0
    },
    {
      "name": "hybrid_binary_bm25",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "visual_sim_binary",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(colpali_embedding_binary)), v)), max, patch), querytoken)"
        },
        {
          "name": "text_sim",
          "expression": "bm25(document_title)"
        }
      ],
      "first_phase": "visual_sim_binary",
      "second_phase": {
        "expression": "text_sim",
        "rerank_count": 100
      },
      "timeout": 2.0
    }
  ]
}
