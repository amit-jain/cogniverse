{
  "name": "audio_content",
  "document": {
    "name": "audio_content",
    "fields": [
      {
        "name": "audio_id",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "audio_title",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "creation_timestamp",
        "type": "long",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "audio_transcript",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "audio_path",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "audio_duration",
        "type": "double",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "audio_language",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "acoustic_embedding",
        "type": "tensor<float>(v[512])",
        "indexing": [
          "attribute",
          "index"
        ],
        "index": {
          "hnsw": {
            "max-links-per-node": 16,
            "neighbors-to-explore-at-insert": 200
          }
        }
      },
      {
        "name": "semantic_embedding",
        "type": "tensor<bfloat16>(token{}, v[128])",
        "indexing": [
          "attribute"
        ]
      },
      {
        "name": "semantic_embedding_binary",
        "type": "tensor<int8>(token{}, v[16])",
        "indexing": [
          "attribute",
          "index"
        ]
      }
    ]
  },
  "fieldsets": [
    {
      "name": "default",
      "fields": [
        "audio_title",
        "audio_transcript"
      ]
    }
  ],
  "rank_profiles": [
    {
      "name": "default",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(semantic_embedding_binary)), v)), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "transcript_search",
      "first_phase": "bm25(audio_title) + bm25(audio_transcript)",
      "timeout": 2.0
    },
    {
      "name": "acoustic_similarity",
      "inputs": [
        {
          "name": "query(acoustic_query)",
          "type": "tensor<float>(v[512])"
        }
      ],
      "first_phase": "closeness(field, acoustic_embedding)",
      "timeout": 2.0
    },
    {
      "name": "semantic_float",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(semantic_embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "semantic_binary",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(semantic_embedding_binary)), v)), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "phased_semantic",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        },
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(semantic_embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(semantic_embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "second_phase": {
        "expression": "max_sim",
        "rerank_count": 100
      },
      "timeout": 5.0
    },
    {
      "name": "hybrid_semantic_bm25",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "semantic_sim",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(semantic_embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "text_score",
          "expression": "bm25(audio_title) + bm25(audio_transcript)"
        }
      ],
      "first_phase": "semantic_sim",
      "second_phase": {
        "expression": "text_score",
        "rerank_count": 100
      },
      "timeout": 2.0
    },
    {
      "name": "hybrid_acoustic_bm25",
      "inputs": [
        {
          "name": "query(acoustic_query)",
          "type": "tensor<float>(v[512])"
        }
      ],
      "functions": [
        {
          "name": "acoustic_score",
          "expression": "closeness(field, acoustic_embedding)"
        },
        {
          "name": "text_score",
          "expression": "bm25(audio_title) + bm25(audio_transcript)"
        }
      ],
      "first_phase": "0.5 * acoustic_score + 0.5 * text_score",
      "timeout": 2.0
    }
  ]
}
