{
  "name": "document_text",
  "document": {
    "name": "document_text",
    "fields": [
      {
        "name": "document_id",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "document_title",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "creation_timestamp",
        "type": "long",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "document_type",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ],
        "attribute": [
          "fast-search"
        ]
      },
      {
        "name": "document_path",
        "type": "string",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "page_count",
        "type": "int",
        "indexing": [
          "summary",
          "attribute"
        ]
      },
      {
        "name": "full_text",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "section_headings",
        "type": "string",
        "indexing": [
          "summary",
          "index"
        ],
        "index": "enable-bm25"
      },
      {
        "name": "embedding",
        "type": "tensor<bfloat16>(token{}, v[128])",
        "indexing": [
          "attribute"
        ]
      },
      {
        "name": "embedding_binary",
        "type": "tensor<int8>(token{}, v[16])",
        "indexing": [
          "attribute",
          "index"
        ]
      }
    ]
  },
  "fieldsets": [
    {
      "name": "default",
      "fields": [
        "document_title",
        "full_text",
        "section_headings"
      ]
    }
  ],
  "rank_profiles": [
    {
      "name": "default",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "bm25_only",
      "first_phase": "bm25(document_title) + bm25(full_text) + bm25(section_headings)",
      "timeout": 2.0
    },
    {
      "name": "float_float",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "binary_binary",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "float_binary",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * unpack_bits(attribute(embedding_binary)), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "phased",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        },
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "second_phase": {
        "expression": "max_sim",
        "rerank_count": 100
      },
      "timeout": 5.0
    },
    {
      "name": "hybrid_float_bm25",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "colbert_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        },
        {
          "name": "text_score",
          "expression": "bm25(document_title) + bm25(full_text) + bm25(section_headings)"
        }
      ],
      "first_phase": "colbert_sim",
      "second_phase": {
        "expression": "text_score",
        "rerank_count": 100
      },
      "timeout": 2.0
    },
    {
      "name": "hybrid_binary_bm25",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "colbert_sim",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "text_score",
          "expression": "bm25(document_title) + bm25(full_text) + bm25(section_headings)"
        }
      ],
      "first_phase": "colbert_sim",
      "second_phase": {
        "expression": "text_score",
        "rerank_count": 100
      },
      "timeout": 2.0
    }
  ]
}
