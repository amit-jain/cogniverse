{
  "name": "knowledge_graph",
  "document": {
    "name": "knowledge_graph",
    "fields": [
      {
        "name": "doc_id",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "tenant_id",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "doc_type",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "name",
        "type": "string",
        "indexing": ["summary", "attribute", "index"],
        "attribute": ["fast-search"],
        "index": "enable-bm25"
      },
      {
        "name": "description",
        "type": "string",
        "indexing": ["summary", "index"],
        "index": "enable-bm25"
      },
      {
        "name": "kind",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "mentions",
        "type": "string",
        "indexing": ["summary"]
      },
      {
        "name": "degree",
        "type": "int",
        "indexing": ["summary", "attribute"]
      },
      {
        "name": "source_node_id",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "target_node_id",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "relation",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "provenance",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "source_doc_id",
        "type": "string",
        "indexing": ["summary", "attribute"],
        "attribute": ["fast-search"]
      },
      {
        "name": "confidence",
        "type": "float",
        "indexing": ["summary", "attribute"]
      },
      {
        "name": "created_at",
        "type": "string",
        "indexing": ["summary", "attribute"]
      },
      {
        "name": "updated_at",
        "type": "string",
        "indexing": ["summary", "attribute"]
      },
      {
        "name": "embedding",
        "type": "tensor<bfloat16>(token{}, v[128])",
        "indexing": ["attribute"]
      },
      {
        "name": "embedding_binary",
        "type": "tensor<int8>(token{}, v[16])",
        "indexing": ["attribute", "index"]
      }
    ]
  },
  "fieldsets": [
    {
      "name": "default",
      "fields": ["name", "description"]
    }
  ],
  "rank_profiles": [
    {
      "name": "default",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        },
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "second_phase": {
        "expression": "max_sim",
        "rerank_count": 100
      },
      "timeout": 5.0
    },
    {
      "name": "binary_only",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "max_sim_hamming",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim_hamming",
      "timeout": 2.0
    },
    {
      "name": "float_float",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "max_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        }
      ],
      "first_phase": "max_sim",
      "timeout": 2.0
    },
    {
      "name": "bm25_only",
      "first_phase": "bm25(name) + bm25(description)",
      "timeout": 2.0
    },
    {
      "name": "hybrid_binary_bm25",
      "inputs": [
        {
          "name": "query(qtb)",
          "type": "tensor<int8>(querytoken{}, v[16])"
        }
      ],
      "functions": [
        {
          "name": "colbert_sim",
          "expression": "sum(reduce(1/(1+ sum(hamming(query(qtb), attribute(embedding_binary)), v)), max, token), querytoken)"
        },
        {
          "name": "text_score",
          "expression": "bm25(name) + bm25(description)"
        }
      ],
      "first_phase": "colbert_sim",
      "second_phase": {
        "expression": "text_score",
        "rerank_count": 100
      },
      "timeout": 2.0
    },
    {
      "name": "hybrid_float_bm25",
      "inputs": [
        {
          "name": "query(qt)",
          "type": "tensor<float>(querytoken{}, v[128])"
        }
      ],
      "functions": [
        {
          "name": "colbert_sim",
          "expression": "sum(reduce(sum(query(qt) * cell_cast(attribute(embedding), float), v), max, token), querytoken)"
        },
        {
          "name": "text_score",
          "expression": "bm25(name) + bm25(description)"
        }
      ],
      "first_phase": "colbert_sim",
      "second_phase": {
        "expression": "text_score",
        "rerank_count": 100
      },
      "timeout": 2.0
    }
  ]
}
