Thumbs.db

# Project specific
/data/*
!**/dataset/
!libs/**/data/

# Planning / design scratch — local-only working space.
# Anything ready to ship as committed knowledge lives under docs/
# (modules/, user/, architecture/, changelog/); docs/plan/ holds
# in-flight design notes that haven't been executed yet.
/docs/plan/

# Testset: only track our authored evaluation artifacts
# Third-party data is fetched by scripts/download_test_data.sh
!/data/testset/
/data/testset/*
!/data/testset/dataset_summary.md
!/data/testset/evaluation/
/data/testset/evaluation/*
!/data/testset/evaluation/extract_sample_video_queries.py
!/data/testset/evaluation/sample_videos_retrieval_queries.json
!/data/testset/evaluation/processed/
/data/testset/evaluation/processed/*
!/data/testset/evaluation/bright_video_probes.csv

# DSPy training set — checked-in fixture data the BootstrapFewShot
# compile pass + ClaimExtractor integration tests depend on.
!/data/training/
!/data/training/**
!/data/testset/evaluation/processed/descriptions/
!/data/testset/evaluation/processed/transcripts/
!/data/testset/evaluation/processed/metadata/
archive*
poc*
*.log
logs/
.byaldi/
.specstory/
test_results/
optimization_results/
outputs/
video_rag_agent/

# Debug files
debug_*.py
check_*.py
test_vespa_*.py
test_float_*.py

# Model files
*.bin
*.pth
*.onnx
*.safetensors

# Large data files
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz

# Integration-test goldens are produced by RECORD_GOLDEN=1 pytest runs
# (see scripts/record_test_goldens.sh). Don't track them in git —
# regenerate locally before running the byte-equal replay suites.
tests/**/goldens/

# ...except the joint-trace ColBERT goldens: they are the pinned contract the
# suite compares against with a tolerance, and must be present so the suite
# runs on a fresh checkout (a missing golden errors, not skips).
!tests/core/integration/goldens/
!tests/core/integration/goldens/*.npy
!tests/core/integration/goldens/*.json

# Temporary files
*.tmp
*.temp
.cache/
temp/

# Test outputs
.coverage
.coverage.*
coverage.xml
htmlcov/
htmlcov_*/

# Claude configuration (agents and rules are committed, settings are not)
.claude/*
!.claude/agents/
!.claude/rules/

# Generated files
configs/schemas/ranking_strategies.json

# Ideas folder (future implementations)
ideas/
docs/internal/
docs/plan/
coverage_*.xml

# MkDocs generated site
site/

# Database and backup files
*.db
*.bak

# Test artifacts
failing_test_files.txt

